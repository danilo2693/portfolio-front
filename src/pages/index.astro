---
export const prerender = false;
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.tsx";
import Experience from "../components/sections/Experience.astro";
import Projects from "../components/sections/Projects.astro";
import About from "../components/sections/About.astro";
import Contact from "../components/sections/Contact.astro";
import { fetchGraphQL } from "../lib/api";

const lang = Astro.url.searchParams.get("lang") || "en";
const isDraft = Astro.cookies.has("preview_mode");

const GET_SITE_DATA = `
  query GetSiteData($locale: I18NLocaleCode = "en", $status: PublicationStatus = PUBLISHED) {
    about (locale: $locale, status: $status) {
      description
      cv { url }
      email
      links { icon title url }
      name
      photos { url }
      summary
    }
    experiences (locale: $locale, status: $status) {
      companyName
      description
      title
      periodTime
    }
    projects (locale: $locale, status: $status) {
      description
      githubUrl
      siteUrl
      stack { icon title }
      title
      photos { url }
    }
  }
`;
// Fetch using the new GraphQL helper
const gqlResponse = await fetchGraphQL(
  GET_SITE_DATA,
  { locale: lang },
  isDraft,
);
const siteData = gqlResponse?.data ?? null;
console.log({ siteData });
let about = null,
  experiences = [],
  projects = [],
  totalProjects = 0;

if (!siteData) {
  console.error("Failed to load site data");
} else {
  about = siteData.about;
  experiences = siteData.experiences;
  projects = siteData.projects;
  totalProjects = siteData.projects.length;
}
---

<Layout title="Portfolio">
  <Header
    client:load
    initialLang={lang as "en" | "es"}
    isHome={true}
    isDraft={isDraft}
  />

  <main class="pt-20">
    <Experience lang={lang} experiences={experiences || []} about={about} />
    <Projects lang={lang} projects={projects} totalProjects={totalProjects} />
    <About lang={lang} about={about} />
    <Contact lang={lang} />
  </main>
</Layout>
