---
import { Image } from "astro:assets";
import { FolderGit2, ExternalLink } from "lucide-react";
import RichText from "../RichText.astro";
import EmptyState from "../EmptyState.astro";
import { useTranslations } from "../../i18n/utils";
interface StackData {
  id: number;
  title: string;
  icon: string;
}

interface ProjectData {
  id: number;
  documentId: string;
  title: string;
  description: any[];
  siteUrl: string;
  githubUrl: string;
  photos: any[];
  stack: StackData[];
}

interface Props {
  lang: string;
  projects: ProjectData[];
  totalProjects?: number;
}

const { lang, projects = [], totalProjects = 0 } = Astro.props;
const t = useTranslations(lang as any);

function getImageUrl(photo: any) {
  if (!photo || !photo.url) return "";
  const url = import.meta.env.STRAPI_URL || "http://127.0.0.1:1337";
  return photo.url.startsWith("http") ? photo.url : `${url}${photo.url}`;
}
---

<script>
  import { register } from "swiper/element/bundle";
  register();

  document.addEventListener("click", (e) => {
    const dialog = e.target as HTMLDialogElement;
    if (dialog.tagName === "DIALOG") {
      dialog.close();
    }
  });
</script>

<section id="projects" class="flex items-center justify-center pb-20">
  <div class="max-w-5xl w-full mx-auto p-6">
    <h2
      class="text-4xl font-bold text-left flex items-center justify-left gap-2"
    >
      <FolderGit2 size={32} />
      {t("section.projects")}
    </h2>
    <div
      class="mb-12 h-px w-40 bg-gradient-to-r from-blue-400/70 to-transparent"
    >
    </div>
    <div class="grid grid-cols-1 gap-8">
      {
        projects.length > 0 ? (
          projects.map((project) => (
            <div class="flex gap-4 h-full sm:h-64 sm:flex-row flex-col overflow-hidden transition-all duration-300 group">
              {project.photos && project.photos.length > 0 ? (
                <>
                  <div
                    class="w-full sm:w-1/2 rounded-3xl overflow-hidden relative cursor-pointer group shrink-0"
                    onclick={`document.getElementById('gallery-modal-${project.id}').showModal()`}
                  >
                    <Image
                      src={getImageUrl(project.photos[0])}
                      alt={project.title}
                      inferSize={true}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    />
                    {project.photos.length > 1 && (
                      <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 flex items-center justify-center transition-opacity duration-300">
                        <span class="text-white text-sm font-medium px-4 py-2 bg-black/60 rounded-full backdrop-blur-sm">
                          + {project.photos.length - 1} Images
                        </span>
                      </div>
                    )}
                  </div>

                  <dialog
                    id={`gallery-modal-${project.id}`}
                    class="w-full h-full max-w-none max-h-none m-0 bg-transparent backdrop:bg-black/20 backdrop:backdrop-blur-md p-0 hidden open:flex items-center justify-center"
                  >
                    <div class="relative w-full h-full flex flex-col items-center justify-center p-4 md:p-12">
                      <button
                        onclick={`document.getElementById('gallery-modal-${project.id}').close()`}
                        class="absolute top-4 right-4 md:top-8 md:right-8 text-white bg-blue-600 hover:bg-blue-700 shadow-lg z-50 p-2 rounded-full transition-colors cursor-pointer"
                        aria-label="Close Gallery"
                      >
                        <svg
                          class="w-8 h-8"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M6 18L18 6M6 6l12 12"
                          />
                        </svg>
                      </button>

                      <swiper-container
                        navigation="true"
                        pagination="true"
                        keyboard="true"
                        class="w-full h-full max-w-6xl"
                      >
                        {project.photos.map((photo: any) => (
                          <swiper-slide class="flex items-center justify-center w-full h-full">
                            <img
                              src={getImageUrl(photo)}
                              alt={project.title}
                              class="max-w-full max-h-full object-contain select-none"
                              loading="lazy"
                            />
                          </swiper-slide>
                        ))}
                      </swiper-container>
                    </div>
                  </dialog>
                </>
              ) : (
                <div class="w-full sm:w-1/2 h-64 bg-gray-200 dark:bg-gray-800 flex items-center justify-center shrink-0">
                  <span class="text-gray-400">No Image</span>
                </div>
              )}

              <div class="w-full sm:w-1/2 flex flex-col justify-between gap-2">
                <h3 class="text-2xl font-bold">{project.title}</h3>
                {project.stack && project.stack.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {project.stack.map((tech) => (
                      <div
                        class="flex items-center gap-1.5 px-2 bg-gray-100 dark:bg-gray-900 rounded-lg text-xs font-medium text-gray-700 dark:text-gray-300 border border-gray-200 dark:border-gray-800"
                        title={tech.title}
                      >
                        {tech.icon && (
                          <div
                            class="w-4 h-4 [&>svg]:w-4 [&>svg]:h-4"
                            set:html={tech.icon}
                          />
                        )}
                        <span>{tech.title}</span>
                      </div>
                    ))}
                  </div>
                )}
                <div class="text-gray-600 dark:text-gray-400 line-clamp-3 prose dark:prose-invert max-w-none">
                  <RichText data={project.description} />
                </div>
                <div class="flex items-center gap-4 self-start">
                  {project.siteUrl && (
                    <a
                      href={project.siteUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex-1 px-2 flex items-center justify-center gap-2 text-center bg-blue-600 hover:bg-blue-700 text-white font-medium py-2.5 rounded-xl transition-colors"
                    >
                      <ExternalLink size={18} />
                      {t("projects.preview")}
                    </a>
                  )}
                  {project.githubUrl && (
                    <a
                      href={project.githubUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex-1 px-2 flex items-center justify-center gap-2 text-center bg-gray-900 hover:bg-gray-800 dark:bg-gray-800 dark:hover:bg-gray-700 text-white font-medium py-2.5 rounded-xl transition-colors"
                    >
                      <svg
                        class="w-[18px] h-[18px]"
                        viewBox="0 0 1024 1024"
                        fill="none"
                      >
                        <path
                          fill="currentColor"
                          fill-rule="evenodd"
                          d="M512 0C229.12 0 0 229.12 0 512c0 226.56 146.56 417.92 350.08 485.76 25.6 4.48 35.2-10.88 35.2-24.32 0-12.16-.64-52.48-.64-95.36-128.64 23.68-161.92-31.36-172.16-60.16-5.76-14.72-30.72-60.16-52.48-72.32-17.92-9.6-43.52-33.28-.64-33.92 40.32-.64 69.12 37.12 78.72 52.48 46.08 77.44 119.68 55.68 149.12 42.24 4.48-33.28 17.92-55.68 32.64-68.48-113.92-12.8-232.96-56.96-232.96-252.8 0-55.68 19.84-101.76 52.48-137.6-5.12-12.8-23.04-65.28 5.12-135.68 0 0 42.88-13.44 140.8 52.48 40.96-11.52 84.48-17.28 128-17.28s87.04 5.76 128 17.28c97.92-66.56 140.8-52.48 140.8-52.48 28.16 70.4 10.24 122.88 5.12 135.68 32.64 35.84 52.48 81.28 52.48 137.6 0 196.48-119.68 240-233.6 252.8 18.56 16 34.56 46.72 34.56 94.72 0 68.48-.64 123.52-.64 140.8 0 13.44 9.6 29.44 35.2 24.32C877.44 929.92 1024 737.92 1024 512 1024 229.12 794.88 0 512 0"
                          clip-rule="evenodd"
                        />
                      </svg>
                      {t("projects.code")}
                    </a>
                  )}
                </div>
              </div>
            </div>
          ))
        ) : (
          <EmptyState message={t("empty.projects")} />
        )
      }
    </div>

    {
      totalProjects > projects.length && (
        <div class="mt-12 flex justify-center">
          <a
            href={`/all-projects?lang=${lang}`}
            class="inline-flex items-center gap-2 px-6 py-3 bg-white dark:bg-gray-800 text-gray-900 dark:text-white border border-gray-200 dark:border-gray-700 hover:border-blue-500 dark:hover:border-blue-500 hover:text-blue-600 dark:hover:text-blue-400 font-medium rounded-full transition-all duration-300 shadow-sm"
          >
            {t("projects.view_all")}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M5 12h14" />
              <path d="m12 5 7 7-7 7" />
            </svg>
          </a>
        </div>
      )
    }
  </div>
</section>

<style>
  swiper-container {
    --swiper-navigation-size: 24px;
    --swiper-navigation-color: #ffffff;
    --swiper-navigation-sides-offset: 16px;
    --swiper-pagination-color: #ffffff;
  }

  swiper-container::part(button-prev),
  swiper-container::part(button-next) {
    background-color: #2563eb; /* bg-blue-600 */
    color: white;
    width: 40px;
    height: 40px;
    padding: 14px;
    border-radius: 9999px; /* rounded-full */
    box-shadow:
      0 10px 15px -3px rgba(0, 0, 0, 0.1),
      0 4px 6px -4px rgba(0, 0, 0, 0.1); /* shadow-lg */
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s ease-in-out;
  }

  @media (min-width: 768px) {
    swiper-container {
      --swiper-navigation-sides-offset: 32px;
    }
  }

  swiper-container::part(button-prev):hover,
  swiper-container::part(button-next):hover {
    background-color: #1d4ed8; /* hover:bg-blue-700 */
  }
</style>
