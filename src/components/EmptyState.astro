---
import { Inbox } from "lucide-react";

interface Props {
  message: string;
}

const { message } = Astro.props;
---

<div class="col-span-full flex flex-col items-center justify-center text-gray-500 dark:text-gray-400 py-16 px-4 border-2 border-dashed border-gray-200 dark:border-gray-800 rounded-3xl bg-gray-50/50 dark:bg-gray-900/50">
  <Inbox className="w-12 h-12 mb-4 text-gray-400 dark:text-gray-600" />
  <p class="text-lg font-medium text-center">{message}</p>
</div>
